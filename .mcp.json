{
	"mcpServers": {
		"svelte": {
			"type": "stdio",
			"command": "npx",
			"env": {},
			"args": ["-y", "@sveltejs/mcp"]
		},
		"chrome-devtools": {
			"command": "npx",
			"args": ["chrome-devtools-mcp@latest", "--autoConnect", "--channel=stable"],
			"autoApprove": ["navigate_page", "performance_start_trace"]
		}
	}
}
